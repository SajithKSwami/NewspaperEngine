# GEMINI_API_KEY: Required for entity extraction and AI features.
# Get a key at https://aistudio.google.com → API Keys
# Copy this file to .env.local and fill in your key. Never commit .env.local.
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this app is hosted (used in production).
APP_URL="http://localhost:3000"

# INGEST_CRON: Cron expression for scheduled ingestion (default: every 2 hours).
# Examples: "0 */2 * * *" = every 2h, "*/30 * * * *" = every 30min
INGEST_CRON="0 */2 * * *"
